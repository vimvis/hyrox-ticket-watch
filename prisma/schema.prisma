generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TicketStatus {
  unknown
  sold_out
  available
  error
}

enum NotificationChannel {
  email
}

enum NotificationStatus {
  queued
  sent
  failed
}

enum MonitorRunStatus {
  running
  success
  partial_failure
  failed
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String          @map("password_hash")
  name            String?
  emailVerifiedAt DateTime?       @map("email_verified_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  watchers        TicketWatcher[]
  notifications   Notification[]

  @@map("users")
}

model Event {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  eventUrl      String        @map("event_url")
  ticketUrl     String        @map("ticket_url")
  location      String?
  startDate     DateTime?     @map("start_date") @db.Date
  endDate       DateTime?     @map("end_date") @db.Date
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  ticketOptions TicketOption[]
  monitorRuns   MonitorRun[]

  @@map("events")
}

model TicketOption {
  id             String           @id @default(cuid())
  eventId        String           @map("event_id")
  eventDate      DateTime         @map("event_date") @db.Date
  weekdayLabel   String           @map("weekday_label")
  divisionCode   String           @map("division_code")
  divisionName   String           @map("division_name")
  categoryCode   String           @map("category_code")
  categoryName   String           @map("category_name")
  displayLabel   String           @map("display_label")
  sourceSelector Json?            @map("source_selector")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  event          Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  watchers       TicketWatcher[]
  statusLogs     TicketStatusLog[]

  @@unique([eventId, eventDate, divisionCode, categoryCode])
  @@map("ticket_options")
}

model TicketWatcher {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  ticketOptionId  String         @map("ticket_option_id")
  isActive        Boolean        @default(true) @map("is_active")
  lastKnownStatus TicketStatus   @default(unknown) @map("last_known_status")
  lastCheckedAt   DateTime?      @map("last_checked_at")
  lastNotifiedAt  DateTime?      @map("last_notified_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketOption    TicketOption   @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)
  notifications   Notification[]

  @@unique([userId, ticketOptionId])
  @@map("ticket_watchers")
}

model MonitorRun {
  id                  String           @id @default(cuid())
  eventId             String           @map("event_id")
  status              MonitorRunStatus @default(running)
  checkedOptionsCount Int              @default(0) @map("checked_options_count")
  availableCount      Int              @default(0) @map("available_count")
  soldOutCount        Int              @default(0) @map("sold_out_count")
  errorCount          Int              @default(0) @map("error_count")
  startedAt           DateTime         @default(now()) @map("started_at")
  finishedAt          DateTime?        @map("finished_at")
  errorMessage        String?          @map("error_message")
  event               Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  statusLogs          TicketStatusLog[]

  @@map("monitor_runs")
}

model TicketStatusLog {
  id             String       @id @default(cuid())
  ticketOptionId String       @map("ticket_option_id")
  monitorRunId   String       @map("monitor_run_id")
  status         TicketStatus
  rawText        String?      @map("raw_text")
  sourcePayload  Json?        @map("source_payload")
  capturedAt     DateTime     @default(now()) @map("captured_at")
  ticketOption   TicketOption @relation(fields: [ticketOptionId], references: [id], onDelete: Cascade)
  monitorRun     MonitorRun   @relation(fields: [monitorRunId], references: [id], onDelete: Cascade)

  @@map("ticket_status_logs")
}

model Notification {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  ticketWatcherId String              @map("ticket_watcher_id")
  channel         NotificationChannel @default(email)
  status          NotificationStatus  @default(queued)
  recipient       String
  subject         String
  payload         Json?
  sentAt          DateTime?           @map("sent_at")
  errorMessage    String?             @map("error_message")
  createdAt       DateTime            @default(now()) @map("created_at")
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketWatcher   TicketWatcher       @relation(fields: [ticketWatcherId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
